# Default MCP server selection
MCP_DEFAULT_SERVER=cluster

# Default transport: stdio, sse, or streamable-http
MCP_DEFAULT_TRANSPORT=streamable-http

# Logging
MCP_LOG_LEVEL=INFO

# HTTP bind settings for sse and streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_SSE_PATH=/sse
MCP_MESSAGE_PATH=/messages/
MCP_STREAMABLE_HTTP_PATH=/mcp

# Kubernetes access
# Set MCP_KUBECONFIG when running locally with a kubeconfig file.
# Leave unset in Kubernetes if you want to use in-cluster auth.
MCP_KUBECONFIG=C:\Users\your-user\.kube\config

# Optional: select one context inside the kubeconfig file.
MCP_KUBE_CONTEXT=dev-cluster
